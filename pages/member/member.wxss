.container {
  background-color: #EBEEF0;
  min-height: 100vh;
  padding: 10rpx;
  box-sizing: border-box;
}

.profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 30rpx 0;
  position: relative;
  width: 100%;
  max-width: 700rpx;
  margin-left: auto;
  margin-right: auto;
  margin-top: 10px;
}


.container {
  background: linear-gradient(135deg, #afeef7 0%, #96bde2 100%);
  min-height: 100vh;
  padding: 0rpx;
  box-sizing: border-box;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  font-family: 'Alibaba', sans-serif; 
}
.profile-name, .profile-grade, .profile-card {
  font-family: 'happy', sans-serif;
}
.backgroundImage {
    width: 100%;
    margin-bottom: -17%;
}

.profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 30rpx;
  background: #fff;
  border-radius: 30rpx;
  /* box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); */
  padding: 20rpx 0;
  position: relative;
  width: 100%;
  max-width: 700rpx;
  margin-left: auto;
  margin-right: auto;
}

.profile-avatar {
    width: 50%;
    height: 200rpx;
    border-radius: 50%;
    /* border: 6rpx solid #f0c509; */
    /* box-shadow: 0 6rpx 24rpx #b2ebf2; */
    margin-bottom: auto;
    margin-top: auto;
    margin-left: 5%;
    margin-right: 5%;

    max-width: 40vw;
    max-height: 40vw;
  }

.profile-info {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
}

.profile-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1976d2;
  margin-bottom: 8rpx;
  display: block;
  width: 100%;
}
/* .profile-name::before {
  content: "👦";
  margin-right: 8rpx;
} */

.profile-grade {
  font-size:30rpx;
  color: #388e3c;
  margin-bottom: 8rpx;
  display: block;
}

.profile-no {
  font-size: 28rpx;
  color: #ff9800;
  margin-bottom: 8rpx;
  display: block;
  /* display: flex; */
  /* align-items: center; */
}
/* .profile-no::before {
  content: "🎫";
  margin-right: 8rpx;
  margin-top: 10rpx;
} */

.profile-reward {
  font-size: 28rpx;
  color: #e53935;
  margin-bottom: 8rpx;
  margin-top: 10rpx;

  display: block;
  width: 100%;
}
/* .profile-reward::before {
  content: "⭐";
  margin-right: 8rpx;
} */

.profile-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  padding: 24rpx;
  margin-bottom: 24rpx;
  width: 100%;
  max-width: 700rpx;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.card-section {
  margin-bottom: 18rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.section-title {
  font-size: 37rpx;
  font-weight: bold;
  color: #4fc3f7;
  margin-right: 8rpx;
}
/* .section-title::before {
  content: "💡";
  margin-right: 6rpx;
} */

.info-item {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  margin-bottom: 6rpx;
  color: #333;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.tag {
  background: #ffe082;
  color: #ff6f00;
  border-radius: 20rpx;
  padding: 8rpx 18rpx;
  font-size: 32rpx;
  box-shadow: 0 2rpx 6rpx #ffe08280;
}

.empty-text {
  color: #bdbdbd;
  font-size: 32rpx;
}

.edit-btn,
.register-btn,
.back-btn {
  width: 80vw;
  min-width: 200rpx;
  max-width: 700rpx;
  margin: 30rpx auto 0;
  background: linear-gradient(90deg, #4fc3f7 0%, #81c784 100%);
  color: #fff;
  font-size: 35rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx #4fc3f780;
  height: 100rpx;
  line-height: 80rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border: none;
  box-sizing: border-box;
}

.back-btn[type="warn"] {
  background: linear-gradient(90deg, #ffb74d 0%, #4fc3f7 100%);
}

.not-registered {
  text-align: center;
  margin-top: 120rpx;
}
.not-registered-tip {
  font-size: 32rpx;
  color: #ff9800;
  margin-bottom: 30rpx;
}

@media screen and (max-width: 350px) {
  .profile-avatar {
    width: 100rpx;
    height: 100rpx;
  }
  .profile-name,
  .profile-grade,
  .profile-no,
  .profile-reward {
    font-size: 24rpx;
  }
  .edit-btn,
  .register-btn,
  .back-btn {
    font-size: 24rpx;
    height: 60rpx;
    line-height: 60rpx;
  }
}

.container {
  background-color: #EBEEF0;
  min-height: 100vh;
  padding: 10rpx;
  box-sizing: border-box;
  color: white;
}

.profile-header {
  width: 100%;
  display: flex;
  flex-direction: column;
  background-color: #C02C38;
  border-radius: 30rpx;
  padding: 30rpx 0;

  max-width: 700rpx;
  margin-left: auto;
  margin-right: auto;
  margin-top: 10px;
  margin-bottom: 20rpx;
}
/* .profile-name::before {
  content: "👦";
  margin-right: 8rpx;
} */

.profile-words {
  width: 100%;
  margin-left: 4%;
  font-size: 30rpx;
  line-height: 150%;
}

.profile-name {
  margin-bottom: 2%;
}

.profile-grade {
  margin-bottom: 8rpx;
}
/* .profile-no::before {
  content: "🎫";
  margin-right: 8rpx;
  margin-top: 10rpx;
} */

.profile-reward {
  margin-bottom: 8rpx;
  margin-top: 10rpx;
}
.profile-reward::after {
  content: "⭐";
  margin-right: 8rpx;
}

.profile-card {
  background-color: #C02C38;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  padding: 24rpx;
  margin-bottom: 24rpx;
  width: 100%;
  max-width: 700rpx;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.card-section {
  margin-bottom: 18rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.section-title {
  font-size: 37rpx;
  font-weight: bold;
  margin-right: 8rpx;
}
/* .section-title::before {
  content: "💡";
  margin-right: 6rpx;
} */

.info-item {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
  margin-top: 5%;
}
.tag {
  background: white;
  color: #C02C38;
  border-radius: 20rpx;
  padding: 8rpx 18rpx;
  font-size: 32rpx;
  box-shadow: 0 2rpx 6rpx #ffe08280;
}

.empty-text {
  color: #bdbdbd;
  font-size: 32rpx;
}

.buttons {
  display: flex;
  flex-direction: row;
  width: 80%;

  margin-left: auto;
  margin-right: auto;
}

.edit-btn,
.register-btn,
.back-btn {
  width: 40vw;
  min-width: 100rpx;
  max-width: 250rpx;

  margin: 10px;
  
  background-color: #C02C38;
  color: #fff;
  font-size: 35rpx;
  border-radius: 40rpx;
  height: 100rpx;
  line-height: 80rpx;
  font-weight: bold;

  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.not-registered {
  text-align: center;
  margin-top: 120rpx;
}
.not-registered-tip {
  font-size: 50rpx;
  color: #6BB392;
}
.register-btn {
  margin-top: 30px;
}
.profile-name {
  position: relative;
  width: 30%;
  text-align: center;

  font-size: 40rpx;
  font-weight: bold;
  color: #1976d2;

  margin-bottom: auto;
  margin-top: auto;
  margin-left: 10%;
  margin-right: 1%;
}
/* .profile-name::before {
  content: "👦";
  margin-right: 8rpx;
} */

.profile-detail {
  position: relative;
  width: 70%;
  text-align: center;

  margin-right: 10%;
  margin-left: 5%;
}

.profile-grade {
  font-size:30rpx;
  color: #388e3c;
  margin-bottom: 8rpx;
}

.profile-no {
  font-size: 28rpx;
  color: #ff9800;
  margin-bottom: 8rpx;
}
/* .profile-no::before {
  content: "🎫";
  margin-right: 8rpx;
  margin-top: 10rpx;
} */

.profile-reward {
  font-size: 28rpx;
  color: #e53935;
  margin-bottom: 8rpx;
  margin-top: 10rpx;
}
.profile-reward::before {
  content: "⭐";
  margin-right: 8rpx;
}

.profile-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  padding: 24rpx;
  margin-bottom: 24rpx;
  width: 100%;
  max-width: 700rpx;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.card-section {
  margin-bottom: 18rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.section-title {
  font-size: 37rpx;
  font-weight: bold;
  color: #4fc3f7;
  margin-right: 8rpx;
}
/* .section-title::before {
  content: "💡";
  margin-right: 6rpx;
} */

.info-item {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  margin-bottom: 6rpx;
  color: #333;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.tag {
  background: #ffe082;
  color: #ff6f00;
  border-radius: 20rpx;
  padding: 8rpx 18rpx;
  font-size: 32rpx;
  box-shadow: 0 2rpx 6rpx #ffe08280;
}

.empty-text {
  color: #bdbdbd;
  font-size: 32rpx;
}

.buttons {
  display: flex;
  flex-direction: row;
  width: 80%;

  margin-left: auto;
  margin-right: auto;
}

.edit-btn,
.register-btn,
.back-btn {
  width: 40vw;
  min-width: 100rpx;
  max-width: 250rpx;

  margin: 10px;
  
  background-color: orange;
  color: #fff;
  font-size: 35rpx;
  border-radius: 40rpx;
  height: 100rpx;
  line-height: 80rpx;
  font-weight: bold;

  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.not-registered {
  text-align: center;
  margin-top: 120rpx;
}
.not-registered-tip {
  font-size: 50rpx;
  color: rgb(235, 128, 128);
}

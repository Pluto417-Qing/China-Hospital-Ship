.agreement-container {
  background: linear-gradient(135deg, #fffde4 0%, #e0f7fa 100%);
  min-height: 100vh;
  padding: 40rpx 20rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx #b2ebf280;
  box-sizing: border-box;
  max-width: 700rpx;
  margin: 0 auto;
}

.agreement-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff9800;
  text-align: center;
  margin-bottom: 30rpx;
  letter-spacing: 2rpx;
  position: relative;
  max-width: 90vw;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.agreement-title::before {
  content: "📚";
  margin-right: 10rpx;
}

.agreement-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx #b2ebf280;
  line-height: 1.8;
  min-height: 400rpx;
  max-width: 90vw;
  margin: 0 auto;
  box-sizing: border-box;
  word-break: break-all;
} 
<view class="container">
  <!-- Calligrahy -->
  <image class="calligraphy" src="cloud://cloudbase-1g4b1jysc952b1f5.636c-cloudbase-1g4b1jysc952b1f5-1367750649/calligraphy.jpg"></image>

  <!-- Banner Swiper -->
  <banners class=".banner-swiper"></banners>

  <!-- Offline Activities -->
  <view class="activities" wx:if="{{hasOffLineActivity && offlineActivityText}}" bind:tap="showActivityDetail">线下活动小通知----{{offlineActivityText.title}}</view>
  <view class="activities" wx:else>线下活动小通知----近期暂无线下活动</view>
  
  <!-- Articles -->
  <!-- 中国医院船 -->
  <view class="article-section" style="background-color: #6BB392">
    <view class="section-header">
      <text class="section-title">中国医院船</text>
      <text class="section-more" bind:tap="seeMoreArticles" data-type="中国医院船">更多</text>
    </view>
    <view class="article-list">
      <article 
        wx:for="{{filteredHealthArticles.length > 2 ? filteredHealthArticles.slice(0,2) : filteredHealthArticles}}" 
        wx:key="id" 
        article="{{item}}"
        bind:itemtap="onArticleTap"
      ></article>
    </view>
  </view>
  <!-- 少年百事通 -->
  <view class="article-section" style="background-color: #C02C38;">
    <view class="section-header">
      <text class="section-title">少年百事通</text>
      <text class="section-more" bind:tap="seeMoreArticles" data-type="少年百事通">更多</text>
    </view>
    <view class="article-list">
      <article 
        wx:for="{{filteredNutritionArticles.length > 2 ? filteredNutritionArticles.slice(0,2) : filteredNutritionArticles}}" 
        wx:key="id" 
        article="{{item}}"
        bind:itemtap="onArticleTap"
      ></article>
    </view>
  </view>
</view> 
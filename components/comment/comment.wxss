/* components/comment.wxss */
/* 评价 */
.comments {
  width: 90%;
  display: flex;
  flex-direction: row;

  margin-left: auto;
  margin-right: auto;
  margin-top: 2%;

  border: 1px solid black;
  border-radius: 10px;
  padding-bottom: 3%;
}

/* 文字 */
.yourComs {
  width: 10%;
  font-size: large;
  margin-left: 5%;

  display: flex;
  text-align: center;
  padding-top: 1%;
}

/* 表情 */
.singleComs {
  display: flex;
  flex-direction: row;
  width: 90%;
}

.singleCom {
  width: 33.3%;
  height: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  margin-top: 5%;
}

.singleCom image {
  width: 50%;
  height: 50px;
  margin-left: auto;
  margin-right: auto;
}
